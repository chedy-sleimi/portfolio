---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  switchUrl: string;
  switchLocale: Locale;
}

const { locale, switchUrl, switchLocale } = Astro.props;
const home = getRelativeLocaleUrl(locale, '');
const neotest = getRelativeLocaleUrl(locale, 'neotest');
---

<header>
  <div class="wrap bar">
    <a class="wordmark" href={home} aria-label={t(locale, 'nav.home')}>Chedy Sleimi</a>
    <nav>
      <a href={neotest}>{t(locale, 'nav.neotest')}</a>
      <a href="/cv-chedy-sleimi.pdf">{t(locale, 'nav.cv')}</a>
      <a href={`${home}#contact`}>{t(locale, 'nav.contact')}</a>
      <a class="lang" href={switchUrl} lang={switchLocale} hreflang={switchLocale}
        >{t(locale, 'nav.switch')}</a
      >
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--rule);
  }

  .bar {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    padding-block: 1.1rem;
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    text-decoration: none;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
    font-size: 0.95rem;
  }

  nav a {
    text-decoration: none;
    color: var(--muted);
  }

  nav a:hover {
    color: var(--primary);
  }

  .lang {
    color: var(--ink);
    font-weight: 600;
    border: 1px solid var(--rule);
    padding: 0.1em 0.55em;
    border-radius: 2px;
  }
</style>
